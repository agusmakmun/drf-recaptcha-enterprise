[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .eggs,
    *.egg,
    build,
    dist,
    .tox,
    .coverage,
    htmlcov,
    .pytest_cache,
    .mypy_cache,
    .DS_Store,
    .vscode,
    .idea
per-file-ignores =
    __init__.py:F401
    tests/*:S101
max-complexity = 10
